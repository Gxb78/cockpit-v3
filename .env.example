# Trading Journal COCKPIT v3 — Configuration
# Copie ce fichier en .env et remplis les valeurs.
#
#   copy .env.example .env
#

# Clé API Anthropic pour le parsing narration IA (optionnel)
# Sans cette clé, le parse utilise le fallback regex uniquement.
ANTHROPIC_API_KEY=

# Variables Flask (optionnelles, valeurs par défaut ci-dessous)
# DEBUG=1
# HOST=127.0.0.1
# PORT=5000
# OPEN_BROWSER=1
# APP_URL=http://127.0.0.1:5000/
